# Rust
/target/
debug/
release/
*.rs.bk
*.rlib
*.prof*

# IDE
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# Logs
*.log

# Environment variables
.env
.env.*
!.env.example
!web/.env.example

# Build artifacts
Cargo.lock

# OS specific
.DS_Store
Thumbs.db
*.tmp

# Application runtime
.build/
build/
# Allow source-tree test modules named `build/`
!/src/**/build/
!/src/**/build/tests.rs

# User configuration (tracked separately if needed)
# config.toml

# Web frontend (Node.js / SvelteKit)
web/node_modules/
web/.svelte-kit/
web/build/
web/.env
web/.env.*
web/!.env.example
web/vite.config.ts.timestamp-*
web/test-results/
web/playwright-report/
web/playwright/.cache/

# Tauri desktop app
web/src-tauri/target/
web/src-tauri/gen/
web/src-tauri/Cargo.lock
tmp/

# Dolt database files (added by bd init)
.dolt/
*.db

# Beads: switch to "no-db" mode so the JSONL is the source of truth
# tracked in this repo. .beads/.gitignore handles runtime file
# exclusions (lock files, logs, embeddeddolt, etc.).
!.beads/
!.beads/issues.jsonl
!.beads/config.yaml
!.beads/metadata.json
!.beads/AGENT_NOTE.md
!.beads/README.md
!.beads/migration-guide.md
!.beads/spec-completion-dates.md

# Beads / Dolt files (added by bd init)
.beads-credential-key

# Subagent pipeline artifacts
.pi-handoff/
.pi-subagents/

# Beads / Dolt files (added by bd init)
.beads/proxieddb/
